    "bindings": [
        {
            "source": "ex.game",
            "vhost": "/",
            "destination": "q.game.card-updated",
            "destination_type": "queue",
            "routing_key": "game.card.updated",
            "arguments": {}
        },
        {
            "source": "ex.game.dlx",
            "vhost": "/",
            "destination": "q.game.dlq",
            "destination_type": "queue",
            "routing_key": "",
            "arguments": {}
