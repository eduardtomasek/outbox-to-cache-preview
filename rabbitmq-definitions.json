{
    "exchanges": [
        {
            "name": "ex.game",
            "vhost": "/",
            "type": "topic",
            "durable": true,
            "auto_delete": false,
            "arguments": {}
        },
        {
            "name": "ex.game.dlx",
            "vhost": "/",
            "type": "fanout",
            "durable": true,
            "auto_delete": false,
            "arguments": {}
        }
    ],
    "queues": [
        {
            "name": "q.game.card-updated",
            "vhost": "/",
            "durable": true,
            "auto_delete": false,
            "arguments": {
                "x-dead-letter-exchange": "ex.game.dlx"
